SECRET_KEY=django-insecure-change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# Brevo transactional email API key (Brevo dashboard → SMTP & API → API Keys).
# Leave blank to keep using the console backend (emails print to the log).
BREVO_API_KEY=

# Only needed if your host doesn't give you cron/Task Scheduler access —
# enables the HTTP fallback for the daily welcome/goodbye email sweep.
# Leave blank to disable that endpoint entirely.
CRON_SECRET=
